{
  "version": 2,
  "name": "marketplace-elite-final",
  "alias": ["mplace.vercel.app"],
  "functions": {
    "api/index.js": { "includeFiles": "backend/**" }
  },
  "rewrites": [
    { "source": "/v1/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
