# Database Connection String
# Get this from Supabase Dashboard > Settings > Database > Connection String
# Make sure to include ?pgbouncer=true if deploying to Vercel
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_NEW_PASSWORD]@aws-0-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Other environment variables (add any as needed)
# JWT_SECRET=your_secret_key
# PORT=3001
